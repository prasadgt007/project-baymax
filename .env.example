# NVIDIA API Key for LLMs
NVIDIA_API_KEY="your-nvidia-api-key-here"

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langchain-api-key-here"
LANGCHAIN_PROJECT="project-baymax"

# Google Calendar / Composio
COMPOSIO_API_KEY="your-composio-api-key-here"
COMPOSIO_USER_ID="your-composio-entity-id-here"

# Supabase PostgreSQL connection string
SUPABASE_DB_URI="postgresql://user:password@host:port/database"

# ngrok — for sharing the app with teammates
# Paste your authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN="your-ngrok-authtoken-here"
